// ============================================================================
//  Barber Dashboard — Prisma schema
// ----------------------------------------------------------------------------
//  Designed from CLAUDE-dashboard.md. One salon owner (User) owns one Salon.
//  A Salon has Staff, Services, Clients, Bookings and a live walk-in Queue.
//  Read top-to-bottom: auth -> org -> catalogue -> people -> activity.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  SALON_OWNER
  STAFF
  ADMIN
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

/// Lifecycle of a scheduled appointment (see Calendar feature).
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

/// Lifecycle of a walk-in queue entry (see Queue feature).
enum QueueStatus {
  WAITING
  CALLED
  SERVED
  CANCELLED
}

// ---------------------------------------------------------------------------
// AUTH  — who can log in
// ---------------------------------------------------------------------------

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  fullName     String
  role         Role           @default(SALON_OWNER)
  isActive     Boolean        @default(true)
  salon        Salon?
  refreshTokens RefreshToken[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("users")
}

/// Hashed refresh tokens — lets us revoke a session without touching the access token.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// ORGANISATION — the salon itself
// ---------------------------------------------------------------------------

model Salon {
  id        String    @id @default(uuid())
  name      String
  nameAr    String?
  phone     String?
  address   String?
  timezone  String    @default("Asia/Amman")
  currency  String    @default("JOD")
  ownerId   String    @unique
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  staff     Staff[]
  services  Service[]
  clients   Client[]
  bookings  Booking[]
  queue     QueueEntry[]
  activities ActivityLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("salons")
}

// ---------------------------------------------------------------------------
// CATALOGUE — what the salon offers & who provides it
// ---------------------------------------------------------------------------

model Service {
  id              String            @id @default(uuid())
  salonId         String
  salon           Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name            String
  nameAr          String?
  durationMinutes Int
  priceFils       Int               // money stored as integer minor units (1 JOD = 1000 fils)
  isActive        Boolean           @default(true)
  staffServices   StaffService[]
  bookings        Booking[]
  queueEntries    QueueEntry[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([salonId])
  @@map("services")
}

model Staff {
  id            String         @id @default(uuid())
  salonId       String
  salon         Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  fullName      String
  role          String         @default("Barber")
  avatarUrl     String?
  isActive      Boolean        @default(true)
  workingHours  WorkingHour[]
  staffServices StaffService[]
  bookings      Booking[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([salonId])
  @@map("staff")
}

/// Many-to-many: which staff member can perform which service.
model StaffService {
  staffId   String
  serviceId String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

/// One row per weekday a staff member works.
model WorkingHour {
  id        String  @id @default(uuid())
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday   Weekday
  startTime String  // "09:00"
  endTime   String  // "17:30"
  isOpen    Boolean @default(true)

  @@unique([staffId, weekday])
  @@map("working_hours")
}

// ---------------------------------------------------------------------------
// PEOPLE — the salon's customers
// ---------------------------------------------------------------------------

model Client {
  id          String    @id @default(uuid())
  salonId     String
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  notes       String?
  bookings    Booking[]
  queueEntries QueueEntry[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([salonId, phone])
  @@index([salonId])
  @@map("clients")
}

// ---------------------------------------------------------------------------
// ACTIVITY — bookings, queue, audit feed
// ---------------------------------------------------------------------------

model Booking {
  id          String        @id @default(uuid())
  salonId     String
  salon       Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  staffId     String
  staff       Staff         @relation(fields: [staffId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  startAt     DateTime
  endAt       DateTime
  status      BookingStatus @default(PENDING)
  priceFils   Int           // snapshot of price at booking time
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([salonId, startAt])
  @@index([staffId, startAt])
  @@map("bookings")
}

model QueueEntry {
  id              String      @id @default(uuid())
  salonId         String
  salon           Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?     @relation(fields: [clientId], references: [id])
  guestName       String?     // walk-in without a saved client record
  serviceId       String
  service         Service     @relation(fields: [serviceId], references: [id])
  position        Int
  status          QueueStatus @default(WAITING)
  estimatedWaitMin Int        @default(0)
  joinedAt        DateTime    @default(now())
  calledAt        DateTime?

  @@index([salonId, status, position])
  @@map("queue_entries")
}

/// Powers the dashboard "recent activity" feed.
model ActivityLog {
  id        String   @id @default(uuid())
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  type      String   // e.g. BOOKING_CREATED, QUEUE_CALLED, SERVICE_UPDATED
  message   String
  createdAt DateTime @default(now())

  @@index([salonId, createdAt])
  @@map("activity_logs")
}
